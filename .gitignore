# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

 voor meer info.

# --- AFHANKELIJKHEDEN ---
/node_modules
/.pnp
.pnp.*
# Yarn Berry
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# Andere package managers (voor de zekerheid)
/pnpm-lock.yaml
/package-lock.json

# --- TESTING & COVERAGE ---
/coverage
/.nyc_output

# --- NEXT.JS & PRODUCTIE ---
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# --- OMGEVINGSVARIABELEN (BEVEILIGING) ---
# Belangrijk: commit NOOIT geheime keys!
.env*
!.env.example

# --- IDE & EDITORS ---
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/

# --- BESTURINGSSYSTEMEN ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# --- DEBUG & LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# --- MISC / DIVERSEN ---
*.pem
*.key
.vercel
/node_modules
.turbo
